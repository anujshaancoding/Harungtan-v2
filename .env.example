# Neon Postgres — DATABASE_URL is the POOLED url (host has "-pooler"), DIRECT_URL is the direct one (used for migrations)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-a-secure-random-string"

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Harungtan"

# Cloudinary (image CDN)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_FOLDER="harungtan"


# Email: admin@harungtan.com
# Password: admin123


# Before deploying, remember to:
# Set STRIPE_WEBHOOK_SECRET in your production .env
# Configure the Stripe webhook URL in Stripe Dashboard: https://yourdomain.com/api/webhooks/stripe
# Add your actual CDN hostname to next.config.ts remote patterns if it's not cdn.harungtan.com